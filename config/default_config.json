{
  // ==========================================================================
  //  КОНФИГУРАЦИЯ СИМУЛЯТОРА БАНКОМАТА
  //
  //  Как это работает:
  //   * Файл читается ОДИН РАЗ при запуске (config/default_config.json по
  //     умолчанию, либо путь первым аргументом: atm_sim.exe my_config.json).
  //     Правки применяются на СЛЕДУЮЩЕМ запуске — пересобирать проект не нужно.
  //   * Любой ключ можно опустить — тогда берётся значение по умолчанию.
  //   * Комментарии (// и /* */) здесь разрешены (это НЕ строгий JSON — движок
  //     их игнорирует). Значения — обычный JSON: числа, строки, true/false.
  //
  //  ДЕНЬГИ — в МИНОРНЫХ единицах (как копейки/центы): показываются делённые
  //  на 100. Пример: 50000000 -> «500000.00 EUR», 300000 -> «3000.00 EUR».
  //  ВРЕМЯ — в МОДЕЛЬНЫХ секундах (см. simulation.time_scale ниже).
  // ==========================================================================

  // --- БАНКОМАТ (касса) -----------------------------------------------------
  "atm": {
    // Стартовая наличность в кассе. Из неё выдаются снятия и в неё падают
    // внесения. Если опустеет ниже суммы снятия — операция получит отказ
    // InsufficientCash (это НЕ то же, что нехватка на счёте клиента).
    "initial_cash": 50000000,           // 500000.00 EUR

    // Порог «низкой кассы»: как только касса опускается ниже — на дашборде
    // загорается метка «НИЗКАЯ» (полоса краснеет) и в лог идёт предупреждение.
    "low_cash_threshold": 2000000,      // 20000.00 EUR

    "currency": "EUR"                   // код валюты для вывода (просто подпись)
  },

  // --- КЛИЕНТЫ (входящий поток и что они делают) ----------------------------
  "clients": {
    // Как клиенты приходят во времени:
    //   "poisson" — случайные интервалы (экспоненциальные), как в жизни;
    //   "batch"   — строго равные интервалы.
    // Среднее в обоих случаях одинаково: 60 / arrival_rate_per_minute секунд.
    "arrival_mode": "poisson",

    // Средняя интенсивность прихода — сколько клиентов в МИНУТУ модельного
    // времени. Больше -> длиннее очередь и выше загрузка. Ключевой рычаг
    // нагрузки: если λ/μ (ρ на дашборде) > 1 — система перегружена, очередь
    // растёт. Здесь λ = rate/60 в секунду, μ = 1/service_time.mean_seconds.
    "arrival_rate_per_minute": 4.0,

    // Сколько ВСЕГО клиентов сгенерировать за прогон. Когда все обслужены/ушли
    // — банкомат простаивает (Idle). Больше клиентов -> дольше идёт симуляция.
    "count": 50,

    // Стартовый баланс СЧЁТА каждого клиента (у каждого свой свежий счёт).
    // Снятие на сумму больше баланса -> отказ InsufficientFunds.
    // ПРАВИЛО: чтобы снятия проходили почти всегда, держи это значение
    // >= amount_range.max (тогда снять всегда «по карману»).
    "initial_balance": 500000,          // 5000.00 EUR

    // Относительные веса выбора операции. В сумму 1 сводить НЕ обязательно —
    // нормируются сами. Больше "withdraw" -> больше снятий (нагрузка на кассу);
    // "check_balance" кассу не трогает.
    "operation_weights": {
      "check_balance": 0.3,
      "withdraw": 0.5,
      "deposit": 0.2
    },

    // Диапазон суммы операции (снятие/внесение), выбирается равномерно в
    // [min, max]. Для «проверки баланса» сумма не нужна (0).
    // Крути вместе с initial_balance: max <= initial_balance => 100% снятий
    // проходят; max > initial_balance => часть снятий будет отклоняться.
    "amount_range": { "min": 20000, "max": 300000 },   // 200.00 .. 3000.00 EUR

    // Терпение клиента в очереди (модельные секунды): если прождал дольше
    // своего терпения — уходит не обслуженным (растёт счётчик «Ушли»).
    // Меньше терпение или выше нагрузка -> больше уходов.
    "patience_seconds": { "min": 30, "max": 300 }
  },

  // --- ВРЕМЯ ОБСЛУЖИВАНИЯ (сколько длится одна операция) --------------------
  "service_time": {
    // Распределение длительности обслуживания:
    //   "normal"      — нормальное (mean_seconds, stddev_seconds);
    //   "uniform"     — равномерное в [min_seconds, max_seconds];
    //   "exponential" — экспоненциальное (mean_seconds).
    "distribution": "normal",
    "params": {
      "mean_seconds": 25,     // среднее обслуживание (для normal/exponential).
                              // Меньше -> выше μ -> система быстрее разгребает очередь.
      "stddev_seconds": 7,    // разброс (только для normal)
      "min_seconds": 5        // нижняя отсечка: короче не бывает (время >= 0).
      // "max_seconds": 60    // верхняя граница — используется ТОЛЬКО для uniform.
    }
  },

  // --- ТЕХОБСЛУЖИВАНИЕ (команда maintenance) --------------------------------
  "maintenance": {
    // Вероятность, что стоящий в очереди клиент уйдёт СРАЗУ при начале ТО
    // (0.0 — никто не уходит, 1.0 — уходят все ожидающие).
    "renege_probability": 0.6,

    // Длительность ТО по умолчанию (модельные секунды), если в команде
    // «maintenance start» время не указано. Значение <= 0 => ТО длится до
    // явной команды «maintenance stop».
    "default_duration_seconds": 120,

    // Впускать ли новых клиентов ВО ВРЕМЯ ТО. true — люди подходят и видят,
    // что банкомат недоступен; false — приход приостанавливается до конца ТО.
    "arrivals_continue_during_maintenance": true
  },

  // --- СИМУЛЯЦИЯ (воспроизводимость и темп) ---------------------------------
  "simulation": {
    // Seed генератора случайных чисел. ОДИН И ТОТ ЖЕ seed => полностью
    // воспроизводимый прогон (те же клиенты/суммы/времена). Поменяй, чтобы
    // получить другой случайный сценарий.
    "random_seed": 42,

    // Ускорение МОДЕЛЬНОГО времени относительно реального.
    //   1.0   — реальное время (25 «секунд» обслуживания = 25 секунд ожидания);
    //   100   — в 100 раз быстрее (для быстрых прогонов «на посмотреть»);
    //   всё > 0. Влияет только на ТЕМП, не на статистику.
    "time_scale": 1.0
  },

  // --- ЛОГ (технический журнал в файл) --------------------------------------
  "logging": {
    // Порог важности сообщений: "debug" | "info" | "warn" | "error"
    // (пишутся сообщения этого уровня и выше). "debug" — подробнее всего.
    "level": "info",
    "file": "atm_sim.log"     // куда писать технический лог
  },

  // --- ИНТЕРФЕЙС (живой дашборд в консоли) -----------------------------------
  "ui": {
    // Стартовать в «живом» режиме (дашборд, обновляемый в реальном времени).
    // Нужен настоящий терминал; если вывод перенаправлен (не TTY) — движок сам
    // откатится в командный режim. Переключение на лету: команды «live» / «live off».
    "live_mode": true,

    // Частота перерисовки дашборда, кадров в секунду (>= 1). Больше — плавнее,
    // но чаще перерисовка. Разумно 2–10.
    "refresh_hz": 4,

    // Цвет ANSI: true — цветной вывод; false — монохром. Вне TTY цвет и так
    // отключается автоматически.
    "color": true,

    // ПРИМЕЧАНИЕ: следующие два поля пока НЕ задействованы в отрисовке
    // (лента операций показывает фиксированное число строк, полосы-индикаторы
    // рисуются всегда). Оставлены на будущее; менять их сейчас смысла нет.
    "events_tail": 8,
    "show_progress_bars": true
  }
}
